# Archivos temporales de Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Entornos virtuales (todas las variantes posibles)
.venv/
venv/
env/
bin/
include/
lib/
share/

# Variables de entorno y secretos
.env

# Archivos pesados de librerías nativas
*.so
*.dll
*.dylib

# --- SECCIÓN DE DATOS Y PERSISTENCIA ---
# Bases de datos SQLite (para que no se suban tus .db)
*.db
*.sqlite
*.sqlite3

# Archivos de bitácora o logs de la base de datos
*.db-journal
*.db-wal

# Almacenamiento de Vectores (ChromaDB, Faiss, etc.)
# Evita subir carpetas donde los agentes guardan sus "recuerdos"
storage/
vector_db/
index/

# Documentos de contexto (Si usas una carpeta para PDFs/TXTs masivos)
data/
inputs/

# Otros archivos de sistema
.DS_Store

# ChromaDB local data
chroma_db/
*.parquet
*.sqlite3-journal

# --- AJUSTES FINALES PERSISTENCIA ---
# Archivos temporales de SQLite (evita errores de 'database is locked' en Git)
*.db-shm
*.db-wal

# Carpetas de persistencia de LlamaIndex (por si usas el storage por defecto)
./storage/

# Logs de depuración de VS Code / Codespaces
.vscode/
.history/